    <!-- JavaScript Interactions -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // 1. Initialize Lucide Icons
            lucide.createIcons();

            // 2. Tab Switching Logic
            const btnFoundations = document.getElementById('btn-foundations');
            const btnComponents = document.getElementById('btn-components');
            const tabFoundations = document.getElementById('tab-foundations');
            const tabComponents = document.getElementById('tab-components');

            function switchTab(tab) {
                if (tab === 'foundations') {
                    tabFoundations.style.display = 'block';
                    tabComponents.style.display = 'none';
                    
                    // Update button active states
                    btnFoundations.className = 'font-plex text-[10px] tracking-[2px] uppercase transition-colors text-[#111111] font-bold';
                    btnComponents.className = 'font-plex text-[10px] tracking-[2px] uppercase transition-colors text-[#666666] hover:text-[#111111]';
                } else {
                    tabFoundations.style.display = 'none';
                    tabComponents.style.display = 'block';
                    
                    // Update button active states
                    btnFoundations.className = 'font-plex text-[10px] tracking-[2px] uppercase transition-colors text-[#666666] hover:text-[#111111]';
                    btnComponents.className = 'font-plex text-[10px] tracking-[2px] uppercase transition-colors text-[#111111] font-bold';
                }
            }

            btnFoundations.addEventListener('click', () => switchTab('foundations'));
            btnComponents.addEventListener('click', () => switchTab('components'));

            // 3. Megamenu Toggle Logic
            const megamenuBtn = document.getElementById('megamenu-btn');
            const megamenuDropdown = document.getElementById('megamenu-dropdown');
            const megamenuChevron = document.getElementById('megamenu-chevron');
            const megamenuPlaceholder = document.getElementById('megamenu-placeholder');
            let isMegamenuOpen = false;

            megamenuBtn.addEventListener('click', () => {
                isMegamenuOpen = !isMegamenuOpen;
                
                if (isMegamenuOpen) {
                    megamenuDropdown.classList.replace('-translate-y-4', 'translate-y-0');
                    megamenuDropdown.classList.replace('opacity-0', 'opacity-100');
                    megamenuDropdown.classList.replace('pointer-events-none', 'pointer-events-auto');
                    megamenuChevron.classList.add('rotate-180');
                    megamenuPlaceholder.style.display = 'none';
                } else {
                    megamenuDropdown.classList.replace('translate-y-0', '-translate-y-4');
                    megamenuDropdown.classList.replace('opacity-100', 'opacity-0');
                    megamenuDropdown.classList.replace('pointer-events-auto', 'pointer-events-none');
                    megamenuChevron.classList.remove('rotate-180');
                    megamenuPlaceholder.style.display = 'block';
                }
            });

            // 4. Slider Dot Animation Logic
            const dots = document.querySelectorAll('.slider-dot');
            let activeDot = 0;
            
            setInterval(() => {
                // Remove active class from current dot
                dots[activeDot].classList.remove('dot-active');
                
                // Increment to next dot
                activeDot = (activeDot + 1) % dots.length;
                
                // Add active class to new dot, force reflow to restart CSS animation
                void dots[activeDot].offsetWidth; 
                dots[activeDot].classList.add('dot-active');
            }, 3500);
        });
    </script>
</body>
</html>
